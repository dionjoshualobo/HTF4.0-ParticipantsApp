# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Spotify ──────────────────────────────────────────────────────────────────
# Create an app at: https://developer.spotify.com/dashboard
# ⚠️  Note: These are visible in the browser bundle.
#    For production, proxy the token endpoint via a Supabase Edge Function.
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
VITE_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ─── Google Drive (Edge Function secrets — set via Supabase CLI) ───────────────
# Do NOT put these in .env — set them as edge function secrets:
#   supabase secrets set GDRIVE_SERVICE_ACCOUNT='{"type":"service_account","client_email":...}'
#   supabase secrets set GDRIVE_FOLDER_ID=your-shared-folder-id
# 1. Create a Service Account in Google Cloud Console → IAM → Service Accounts
# 2. Give it "Editor" access to the target Drive folder (share the folder with the SA email)
# 3. Create a JSON key → paste the whole file content as GDRIVE_SERVICE_ACCOUNT

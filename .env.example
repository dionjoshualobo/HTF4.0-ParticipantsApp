# ─── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Spotify ──────────────────────────────────────────────────────────────────
# Create an app at: https://developer.spotify.com/dashboard
# ⚠️  Note: These are visible in the browser bundle.
#    For production, proxy the token endpoint via a Supabase Edge Function.
VITE_SPOTIFY_CLIENT_ID=your-spotify-client-id
VITE_SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ─── Cloudinary (media gallery uploads) ──────────────────────────────────────
# Create a free account at https://cloudinary.com then:
#   1. Dashboard → grab "Cloud name"
#   2. Settings → Upload → Upload presets → Add upload preset
#      - Signing Mode: Unsigned
#      - Folder: htf4 (optional, keeps assets organized)
#      - Allowed formats: jpg,png,gif,webp,mp4,mov,webm
#      - Max file size: 52428800 (50 MB)
#      - Access Mode: public
#   3. Copy the preset name
VITE_CLOUDINARY_CLOUD_NAME=danjl0scr
VITE_CLOUDINARY_UPLOAD_PRESET=hacktofuture
